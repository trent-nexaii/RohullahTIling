---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';

const title = "Wellington Tiling Service Areas | Rohullah Rassuli Tiling";
const description = "Professional tiling services across Wellington — Whitby, Porirua, Lower Hutt, Upper Hutt, Kapiti Coast & more. Local tiler, free quotes. Call 021 026 02044.";
const canonical = "/service-areas";
const breadcrumbs = [{ name: "Home", url: "/" }, { name: "Service Areas" }];
---

<BaseLayout title={title} description={description} canonical={canonical} breadcrumbs={breadcrumbs}>
  <PageHeader title="Tiling Services Across the Wellington Region" breadcrumbs={breadcrumbs} />

  <!-- Intro -->
  <section class="section">
    <div class="container">
      <div class="area-intro fade-in-up">
        <p class="lead-text">Rohullah Rassuli Tiling Services is based in <strong>Whitby</strong> and provides professional tiling across the entire Wellington region. From the northern reaches of the Kapiti Coast to the Hutt Valley and right through to Wellington CBD, we bring the same standard of quality craftsmanship to every project — no matter where you are.</p>
        <p>Whether you need <a href="/services/bathroom-tiling">bathroom tiling</a>, <a href="/services/kitchen-tiling">kitchen splashbacks</a>, <a href="/services/floor-tiling">floor tiling</a>, <a href="/services/waterproofing">waterproofing</a>, or <a href="/services/tile-repairs">tile repairs</a>, we are ready to help. Free quotes are available across all areas listed below.</p>
      </div>
    </div>
  </section>

  <!-- Northern Wellington / Porirua -->
  <section class="section section--light">
    <div class="container">
      <div class="area-section fade-in-up">
        <h2 class="section-title section-title--left">Northern Wellington &amp; Porirua</h2>
        <p class="area-section__description">As our home base, the northern Wellington and Porirua corridor is where you will find us most often. We know the local building styles, substrate conditions, and the kinds of projects homeowners in this area typically undertake. From modern townhouse bathrooms in Aotea to character home renovations in Plimmerton, we have the experience to deliver outstanding results close to home.</p>
        <div class="area-tags">
          <span class="area-tag area-tag--featured">Whitby <span class="area-badge">Home Base</span></span>
          <span class="area-tag">Papakowhai</span>
          <span class="area-tag">Aotea</span>
          <span class="area-tag">Porirua</span>
          <span class="area-tag">Plimmerton</span>
          <span class="area-tag">Pukerua Bay</span>
          <span class="area-tag">Mana</span>
          <span class="area-tag">Titahi Bay</span>
        </div>
        <p class="area-section__services">Our services in this area include <a href="/services/bathroom-tiling">bathroom tiling</a>, <a href="/services/kitchen-tiling">kitchen tiling</a>, <a href="/services/floor-tiling">floor tiling</a>, <a href="/services/waterproofing">waterproofing</a>, <a href="/services/underfloor-heating">underfloor heating</a>, and <a href="/services/tile-repairs">tile repairs</a>.</p>
      </div>
    </div>
  </section>

  <!-- Central Wellington -->
  <section class="section">
    <div class="container">
      <div class="area-section fade-in-up">
        <h2 class="section-title section-title--left">Central Wellington</h2>
        <p class="area-section__description">Wellington city is home to a diverse mix of properties — from heritage villas in Karori and Brooklyn to modern apartments in the CBD and waterfront developments in Kilbirnie and Miramar. We work across all property types, whether it is a compact apartment bathroom renovation or a large-format tiling project in a new-build townhouse. Our attention to detail ensures a premium finish that suits the character of your Wellington home.</p>
        <div class="area-tags">
          <span class="area-tag">Wellington CBD</span>
          <span class="area-tag">Karori</span>
          <span class="area-tag">Kelburn</span>
          <span class="area-tag">Brooklyn</span>
          <span class="area-tag">Newtown</span>
          <span class="area-tag">Island Bay</span>
          <span class="area-tag">Kilbirnie</span>
          <span class="area-tag">Miramar</span>
          <span class="area-tag">Hataitai</span>
          <span class="area-tag">Roseneath</span>
        </div>
        <p class="area-section__services">We offer <a href="/services/bathroom-tiling">bathroom tiling</a>, <a href="/services/kitchen-tiling">kitchen tiling</a>, <a href="/services/floor-tiling">floor tiling</a>, <a href="/services/waterproofing">waterproofing</a>, <a href="/services/underfloor-heating">underfloor heating</a>, and <a href="/services/tile-repairs">tile repairs</a> across central Wellington.</p>
      </div>
    </div>
  </section>

  <!-- Northern Suburbs -->
  <section class="section section--light">
    <div class="container">
      <div class="area-section fade-in-up">
        <h2 class="section-title section-title--left">Northern Suburbs</h2>
        <p class="area-section__description">The northern suburbs of Johnsonville, Tawa, and Churton Park are a natural extension of our Whitby base. These rapidly growing suburbs feature a mix of established homes and new developments, all of which benefit from quality tiling. Whether you are renovating an existing bathroom or fitting out a brand-new kitchen, we bring professional-grade results to every job in this area.</p>
        <div class="area-tags">
          <span class="area-tag">Johnsonville</span>
          <span class="area-tag">Tawa</span>
          <span class="area-tag">Churton Park</span>
        </div>
        <p class="area-section__services">Services include <a href="/services/bathroom-tiling">bathroom tiling</a>, <a href="/services/kitchen-tiling">kitchen tiling</a>, <a href="/services/floor-tiling">floor tiling</a>, <a href="/services/waterproofing">waterproofing</a>, <a href="/services/underfloor-heating">underfloor heating</a>, and <a href="/services/tile-repairs">tile repairs</a>.</p>
      </div>
    </div>
  </section>

  <!-- Hutt Valley -->
  <section class="section">
    <div class="container">
      <div class="area-section fade-in-up">
        <h2 class="section-title section-title--left">Hutt Valley</h2>
        <p class="area-section__description">The Hutt Valley is one of the Wellington region's most active renovation markets, with homeowners across Lower Hutt, Petone, Upper Hutt, and Eastbourne investing in bathroom and kitchen upgrades. We provide the full range of tiling services throughout the valley, from waterproofing and underfloor heating installations through to complete bathroom and kitchen tiling. Our experience with both older homes and new builds means we can handle any challenge the Hutt Valley presents.</p>
        <div class="area-tags">
          <span class="area-tag">Lower Hutt</span>
          <span class="area-tag">Petone</span>
          <span class="area-tag">Upper Hutt</span>
          <span class="area-tag">Eastbourne</span>
        </div>
        <p class="area-section__services">All of our services are available in the Hutt Valley: <a href="/services/bathroom-tiling">bathroom tiling</a>, <a href="/services/kitchen-tiling">kitchen tiling</a>, <a href="/services/floor-tiling">floor tiling</a>, <a href="/services/waterproofing">waterproofing</a>, <a href="/services/underfloor-heating">underfloor heating</a>, and <a href="/services/tile-repairs">tile repairs</a>.</p>
      </div>
    </div>
  </section>

  <!-- Kapiti Coast -->
  <section class="section section--light">
    <div class="container">
      <div class="area-section fade-in-up">
        <h2 class="section-title section-title--left">Kapiti Coast</h2>
        <p class="area-section__description">The Kapiti Coast is a growing region with a strong demand for quality tradespeople. From beachside homes in Raumati to new subdivisions in Paraparaumu and established properties in Waikanae, we are pleased to extend our tiling services to this beautiful part of the Wellington region. The relaxed coastal lifestyle deserves tiling that is both beautiful and built to withstand the coastal conditions.</p>
        <div class="area-tags">
          <span class="area-tag">Paraparaumu</span>
          <span class="area-tag">Waikanae</span>
          <span class="area-tag">Raumati</span>
        </div>
        <p class="area-section__services">Kapiti Coast services include <a href="/services/bathroom-tiling">bathroom tiling</a>, <a href="/services/kitchen-tiling">kitchen tiling</a>, <a href="/services/floor-tiling">floor tiling</a>, <a href="/services/waterproofing">waterproofing</a>, <a href="/services/underfloor-heating">underfloor heating</a>, and <a href="/services/tile-repairs">tile repairs</a>.</p>
      </div>
    </div>
  </section>

  <!-- Don't see your area? -->
  <section class="section">
    <div class="container">
      <div class="area-not-listed fade-in-up">
        <h2 class="section-title">Don't See Your Area?</h2>
        <p>We may still be able to help. If your suburb or town is not listed above, get in touch and we will let you know if we can service your area. We are always happy to discuss your project regardless of location.</p>
        <div class="area-not-listed__buttons">
          <a href="/contact" class="btn btn-primary">Contact Us</a>
          <a href="tel:+6402102602044" class="btn btn-outline">Call 021 026 02044</a>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    heading="Ready to Start Your Tiling Project?"
    text="Get in touch with Rohullah Rassuli Tiling Services for a free, no-obligation quote. We'd love to help bring your vision to life."
    variant="gold"
  />
</BaseLayout>

<style>
  /* Intro */
  .area-intro {
    max-width: 800px;
  }
  .lead-text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-dark-text);
    margin-bottom: 1rem;
  }
  .area-intro p {
    line-height: 1.8;
    color: var(--color-body-text);
  }
  .area-intro a {
    color: var(--color-primary-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .area-intro a:hover {
    color: var(--color-primary);
  }

  /* Area Sections */
  .area-section__description {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-body-text);
    margin-bottom: 1.5rem;
    max-width: 800px;
  }
  .area-section__services {
    margin-top: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-body-text);
  }
  .area-section__services a {
    color: var(--color-primary-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .area-section__services a:hover {
    color: var(--color-primary);
  }

  /* Area Tags */
  .area-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .area-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    background: var(--color-white);
    border: 1px solid var(--color-border-warm);
    border-radius: 100px;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-dark-text);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .area-tag:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(212, 160, 23, 0.1);
  }
  .area-tag--featured {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-dark-text);
    font-weight: 700;
  }
  .area-tag--featured:hover {
    background: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
  }
  .area-badge {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-white);
    color: var(--color-primary-dark);
    padding: 2px 8px;
    border-radius: 100px;
    font-weight: 700;
  }

  /* Don't see your area */
  .area-not-listed {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }
  .area-not-listed p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-body-text);
    margin-bottom: 2rem;
  }
  .area-not-listed__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.fade-in-up').forEach((el) => observer.observe(el));
</script>
