---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTASection from '../components/CTASection.astro';

const title = "Tiling Portfolio Wellington | Rohullah Rassuli Projects";
const description = "View our portfolio of completed tiling projects across Wellington. Bathroom renovations, shower tiling, commercial work & more. See the quality for yourself.";
const canonical = "/portfolio";
const breadcrumbs = [{ name: "Home", url: "/" }, { name: "Portfolio" }];

const projects = [
  {
    title: "Residential Bathroom — Large-Format Porcelain Tiles",
    image: "/images/portfolio/bathroom-porcelain-shower.jpg",
    alt: "Walk-in shower with large-format beige porcelain tiles — floor-to-ceiling installation in a Wellington home",
    description: "A full bathroom tiling project featuring large-format beige porcelain tiles installed floor-to-ceiling. The walk-in shower includes precisely cut tiles around plumbing penetrations, a stainless steel floor waste with correct falls, and consistent grout lines throughout. This neutral palette creates a warm, spacious feel that works with any bathroom fittings.",
    tags: ["Bathroom Tiling", "Large-Format Tiles", "Walk-in Shower", "Porcelain", "Wellington"],
  },
  {
    title: "Bathroom Renovation — Marble-Look Porcelain",
    image: "/images/portfolio/bathroom-marble-look.jpg",
    alt: "Bathroom renovation with white marble-look porcelain tiles and recessed niche — Wellington tiling project",
    description: "A stunning bathroom renovation using high-gloss white marble-look porcelain tiles. The floor-to-ceiling installation features a recessed niche for storage, carefully cut around plumbing connections, and a seamless transition from wall to floor tiles. The calacatta-style veining adds luxury to this modern Wellington bathroom.",
    tags: ["Bathroom Renovation", "Marble-Look Tiles", "Recessed Niche", "Floor-to-Ceiling"],
  },
  {
    title: "Walk-in Shower — Natural Stone Look",
    image: "/images/portfolio/shower-natural-stone.jpg",
    alt: "Walk-in shower with natural stone-look tiles and frosted privacy window — Wellington home",
    description: "Another angle of a beautifully tiled bathroom featuring natural stone-look porcelain tiles. The large-format tiles minimise grout lines for a clean, modern aesthetic. Tiles are precisely cut around the frosted privacy window frame and plumbing penetrations, demonstrating the attention to detail that goes into every Rohullah Rassuli tiling project.",
    tags: ["Shower Tiling", "Natural Stone Look", "Large-Format", "Porcelain"],
  },
  {
    title: "Designer Bathroom — Green Subway Feature Wall",
    image: "/images/portfolio/bathroom-green-subway.jpg",
    alt: "Modern designer bathroom with green subway tile feature wall, terrazzo floor, and skylight — Wellington bathroom renovation",
    description: "A striking designer bathroom featuring a floor-to-ceiling green glazed subway tile feature wall paired with terrazzo-look floor tiles. The skylight floods the space with natural light, highlighting the hand-glazed finish of the subway tiles. A floating timber vanity with vessel basin completes this contemporary Wellington bathroom renovation. This project showcases our ability to work with multiple tile types and finishes in a single space.",
    tags: ["Subway Tiles", "Feature Wall", "Terrazzo", "Designer Bathroom", "Green Tiles"],
  },
  {
    title: "Commercial Tiling — Geometric Diamond Pattern",
    image: "/images/portfolio/commercial-geometric-pattern.jpg",
    alt: "Commercial tiling project with black and white geometric diamond pattern wall tiles — Wellington commercial space",
    description: "A large-scale commercial tiling installation featuring a bold black and white geometric diamond pattern. This eye-catching design required precise tile alignment across a long wall, with clean white subway tiles above creating a crisp border. Commercial tiling projects like this demand expertise in layout planning, consistent spacing, and working to tight tolerances — all hallmarks of Rohullah Rassuli Tiling Services.",
    tags: ["Commercial Tiling", "Geometric Pattern", "Mosaic", "Black & White", "Feature Wall"],
  },
];
---

<BaseLayout title={title} description={description} canonical={canonical} breadcrumbs={breadcrumbs}>
  <PageHeader title="Our Tiling Portfolio" breadcrumbs={breadcrumbs} />

  <!-- Intro Section -->
  <section class="section section--light">
    <div class="container">
      <div class="portfolio-intro fade-in-up">
        <p>Explore a selection of our recent tiling projects across the Wellington region. From residential bathrooms to commercial spaces, every project reflects our commitment to precision, quality materials, and lasting craftsmanship.</p>
      </div>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="section">
    <div class="container">
      <div class="portfolio-grid">
        {projects.map((project) => (
          <article class="portfolio-item fade-in-up">
            <img
              src={project.image}
              alt={project.alt}
              width="800"
              height="600"
              loading="lazy"
            />
            <div class="portfolio-item-content">
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="portfolio-tags">
                {project.tags.map((tag) => (
                  <span class="portfolio-tag">{tag}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="section section--light">
    <div class="container">
      <div class="portfolio-seo fade-in-up">
        <h2 class="section-title">Wellington Tiling You Can Trust</h2>
        <p>Every project in our portfolio was completed by Rohullah Rassuli personally, right here in the Wellington region. From Whitby and Porirua through to Lower Hutt, Upper Hutt, and Wellington CBD, our work speaks for itself. We use only quality porcelain, ceramic, and natural stone tiles sourced from trusted New Zealand suppliers, paired with premium adhesives and grouts that ensure a lasting finish.</p>
        <p>Whether you are planning a simple bathroom refresh or a full-scale commercial fit-out, the same level of care and craftsmanship goes into every job. Precise cuts, consistent grout lines, correct waterproofing, and a clean, tidy workspace are standard on every Rohullah Rassuli tiling project. We invite you to browse these completed projects and see the quality for yourself — then get in touch for a free, no-obligation quote on your own tiling project.</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTASection
    heading="Ready to Start Your Tiling Project?"
    text="Get in touch today for a free, no-obligation quote. We would love to add your project to our portfolio."
  />
</BaseLayout>

<style>
  .portfolio-intro {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .portfolio-intro p {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--color-text, #333);
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .portfolio-item {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .portfolio-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .portfolio-item img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 4 / 3;
    display: block;
  }

  .portfolio-item-content {
    padding: 1.5rem;
  }

  .portfolio-item-content h3 {
    margin: 0 0 0.75rem;
    font-size: 1.2rem;
    color: var(--color-heading, #1a1a2e);
  }

  .portfolio-item-content p {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text, #555);
  }

  .portfolio-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .portfolio-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 999px;
    background: #fdf4e3;
    color: #8b6914;
  }

  .portfolio-seo {
    max-width: 800px;
    margin: 0 auto;
  }

  .portfolio-seo p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text, #555);
    margin-bottom: 1rem;
  }
</style>
