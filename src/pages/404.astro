---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Rohullah Rassuli Tiling Services"
  description="The page you were looking for could not be found. Browse our tiling services or contact us for a free quote in Wellington."
  canonical="/404"
>
  <section class="section" style="min-height: 60vh; display: flex; align-items: center;">
    <div class="container" style="text-align: center;">
      <h1 style="font-size: 4rem; color: var(--color-primary, #D4A017); margin-bottom: 0.5rem;">404</h1>
      <h2 style="margin-bottom: 1rem;">Page Not Found</h2>
      <p style="font-size: 1.125rem; color: var(--color-text, #555); max-width: 500px; margin: 0 auto 2rem;">
        Sorry, the page you are looking for does not exist or has been moved. Let us help you find what you need.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/" class="btn btn--primary">Back to Home</a>
        <a href="/services" class="btn btn--secondary">View Our Services</a>
        <a href="/contact" class="btn btn--outline">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
