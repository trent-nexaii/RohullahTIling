---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  breadcrumbs?: { name: string; url?: string }[];
  schemas?: string;
  showMobileCTA?: boolean;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  breadcrumbs,
  schemas,
  showMobileCTA = true,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.rohullahtiling.co.nz';
const canonicalUrl = `${siteUrl}${canonical}`;
const currentPath = Astro.url.pathname;

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Rohullah Rassuli Tiling Services",
  "description": "Professional tiling services across the Wellington region.",
  "url": "https://www.rohullahtiling.co.nz",
  "telephone": "+6402102602044",
  "email": "info@rohullahtiling.co.nz",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Whitby",
    "addressRegion": "Wellington",
    "addressCountry": "NZ"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -41.1308,
    "longitude": 174.8717
  },
  "openingHours": "Mo-Fr 08:00-17:00",
  "areaServed": {
    "@type": "Place",
    "name": "Wellington Region"
  },
  "priceRange": "$$"
});

let breadcrumbSchema = '';
if (breadcrumbs && breadcrumbs.length > 0) {
  breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((crumb, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": crumb.name,
      ...(crumb.url ? { "item": `${siteUrl}${crumb.url}` } : {})
    }))
  });
}

const year = new Date().getFullYear();

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/' || currentPath === '';
  return currentPath.startsWith(path);
}

const serviceLinks = [
  { name: 'Bathroom Tiling', href: '/services/bathroom-tiling' },
  { name: 'Kitchen Tiling', href: '/services/kitchen-tiling' },
  { name: 'Floor Tiling', href: '/services/floor-tiling' },
  { name: 'Waterproofing', href: '/services/waterproofing' },
  { name: 'Underfloor Heating', href: '/services/underfloor-heating' },
  { name: 'Tile Repairs', href: '/services/tile-repairs' },
];

const navLinks = [
  { name: 'Services', href: '/services', children: serviceLinks },
  { name: 'Portfolio', href: '/portfolio' },
  { name: 'Service Areas', href: '/service-areas' },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
];
---

<!DOCTYPE html>
<html lang="en-NZ">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="en_NZ" />
  <meta property="og:site_name" content="Rohullah Rassuli Tiling Services" />
  <meta property="og:image" content={`${siteUrl}/images/og-image.svg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Rohullah Rassuli Tiling Services — Professional Tiling Across Wellington" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}/images/og-image.svg`} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Sans:wght@400;500;700&display=swap"
    rel="stylesheet"
  />

  <!-- LocalBusiness Schema -->
  <script type="application/ld+json" set:html={localBusinessSchema} />

  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  )}

  {schemas && (
    <script type="application/ld+json" set:html={schemas} />
  )}
</head>
<body>

  <!-- ========== NAVIGATION ========== -->
  <header class="site-header" id="site-header">
    <div class="nav-container">
      <a href="/" class="logo" aria-label="Rohullah Rassuli Tiling Services — Home">
        <span class="logo-name">ROHULLAH RASSULI</span>
        <span class="logo-tagline">TILING SERVICES</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="nav-desktop" aria-label="Main navigation">
        {navLinks.map((link) =>
          link.children ? (
            <div class="nav-dropdown">
              <a
                href={link.href}
                class={`nav-link${isActive(link.href) ? ' active' : ''}`}
              >
                {link.name}
              </a>
              <ul class="nav-dropdown-menu">
                {link.children.map((child) => (
                  <li>
                    <a href={child.href} class={isActive(child.href) ? 'active' : ''}>
                      {child.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ) : (
            <a
              href={link.href}
              class={`nav-link${isActive(link.href) ? ' active' : ''}`}
            >
              {link.name}
            </a>
          )
        )}
      </nav>

      <!-- Phone Link -->
      <a href="tel:+6402102602044" class="nav-phone" aria-label="Call us at 021 026 02044">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>021 026 02044</span>
      </a>

      <!-- Hamburger Button -->
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile Navigation Overlay -->
    <nav class="nav-mobile" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a href={link.href}>{link.name}</a>
      ))}
      {serviceLinks.map((link) => (
        <a href={link.href} style="font-size: 1.1rem; opacity: 0.8;">{link.name}</a>
      ))}
      <a href="tel:+6402102602044" style="color: var(--color-primary);">021 026 02044</a>
    </nav>
  </header>

  <!-- ========== PAGE CONTENT ========== -->
  <main>
    <slot />
  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-col">
        <a href="/" class="footer-logo" aria-label="Home">
          <span class="logo-name">ROHULLAH RASSULI</span>
          <span class="logo-tagline">TILING SERVICES</span>
        </a>
        <p class="footer-desc">
          Professional tiling services across the Wellington region. Quality craftsmanship, attention to detail, and a commitment to excellence on every project.
        </p>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Contact Us</h3>
        <address class="footer-contact">
          <p>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Whitby, Wellington, New Zealand
          </p>
          <p>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+6402102602044">021 026 02044</a>
          </p>
          <p>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:info@rohullahtiling.co.nz">info@rohullahtiling.co.nz</a>
            <!-- PLACEHOLDER EMAIL — replace with actual email -->
          </p>
          <p>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Mon&ndash;Fri: 8:00 AM &ndash; 5:00 PM
          </p>
        </address>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Quick Links</h3>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/service-areas">Service Areas</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-heading">Our Services</h3>
        <ul class="footer-links">
          {serviceLinks.map((link) => (
            <li><a href={link.href}>{link.name}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <div class="footer-bottom-left">
          <span>&copy; {year} Rohullah Rassuli Tiling Services. All rights reserved.</span>
          <span class="footer-bottom-sep">|</span>
          <a href="/privacy">Privacy Policy</a>
          <span class="footer-bottom-sep">|</span>
          <a href="/terms">Terms of Service</a>
        </div>
        <div class="footer-bottom-right">
          Website designed by <a href="https://www.nexaii.com" target="_blank" rel="noopener noreferrer">Nexaii</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- ========== MOBILE STICKY CTA BAR ========== -->
  {showMobileCTA && (
    <div class="mobile-cta-bar" id="mobile-cta-bar">
      <a href="tel:+6402102602044" class="mobile-cta-btn mobile-cta-phone" aria-label="Call us">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Call Now
      </a>
      <a href="/contact" class="mobile-cta-btn mobile-cta-quote">Get a Free Quote</a>
    </div>
  )}

  <!-- Client-side JS -->
  <script is:inline src="/js/main.js"></script>
</body>
</html>
