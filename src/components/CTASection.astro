---
interface Props {
  heading: string;
  text: string;
  variant?: 'gold' | 'dark';
}

const { heading, text, variant = 'gold' } = Astro.props;
---

<section class={`cta-section cta-section--${variant}`}>
  <div class="container cta-section__inner">
    <h2 class="cta-section__heading">{heading}</h2>
    <p class="cta-section__text">{text}</p>
    <div class="cta-section__buttons">
      <a href="/contact" class="btn btn--primary">Get a Free Quote</a>
      <a href="tel:+6402102602044" class="btn btn--secondary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M22 16.92V19.92C22 20.48 21.56 20.93 21 20.97C20.68 21 20.35 21 20 21C10.61 21 3 13.39 3 4C3 3.65 3 3.32 3.03 3C3.07 2.44 3.52 2 4.08 2H7.08C7.56 2 7.99 2.34 8.07 2.81C8.14 3.27 8.23 3.73 8.36 4.17C8.47 4.55 8.36 4.96 8.07 5.24L6.62 6.69C8.06 9.43 10.57 11.94 13.31 13.38L14.76 11.93C15.04 11.64 15.45 11.53 15.83 11.64C16.27 11.77 16.73 11.86 17.19 11.93C17.66 12.01 18 12.44 18 12.92V15.92C18 16.48 17.56 16.93 17 16.97" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Call 021 026 02044
      </a>
    </div>
  </div>
</section>
